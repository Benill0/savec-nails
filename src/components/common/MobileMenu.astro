---
import { Icon } from "astro-icon/components";
---

<button
  class="menu-trigger"
  id="menu-toggle"
  aria-label="Abrir menú"
  aria-expanded="false"
>
  <div class="button-glow"></div>
  <div class="icon-container">
    <Icon name="lucide:menu" class="icon-menu" />
    <Icon name="lucide:x" class="icon-close" />
  </div>
</button>

<style>
  .menu-trigger {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 210;
    -webkit-tap-highlight-color: transparent;
  }

  .icon-container {
    position: relative;
    width: 38px;
    height: 38px;
    background: var(--gradient-rose);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    overflow: hidden;
    box-shadow: var(--shadow-rose);
    transition: transform 0.2s ease;
  }

  .menu-trigger:hover .icon-container {
    transform: scale(1.08);
  }

  .icon-menu,
  .icon-close {
    position: absolute;
    width: 18px;
    height: 18px;
    transition:
      transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
      opacity 0.25s ease;
  }

  .icon-close {
    opacity: 0;
    transform: rotate(-90deg) scale(0.6);
  }

  /* Glow effect */
  .button-glow {
    position: absolute;
    inset: -3px;
    background: var(--gradient-rose);
    border-radius: 50%;
    opacity: 0;
    filter: blur(8px);
    transition: opacity 0.3s ease;
    z-index: -1;
  }

  .menu-trigger:hover .button-glow {
    opacity: 0.35;
  }

  /* States when overlay is open */
  :global(.is-open) ~ * .icon-menu,
  :global(body.menu-open) .icon-menu {
    opacity: 0;
    transform: rotate(90deg) scale(0.6);
  }

  :global(body.menu-open) .icon-close {
    opacity: 1;
    transform: rotate(0deg) scale(1);
  }

  @media (width >= 64rem) {
    .menu-trigger {
      display: none;
    }
  }
</style>
