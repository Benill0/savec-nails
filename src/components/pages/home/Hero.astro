---
import { contactInfo } from "../../../data/contact";

const heroImg =
  "https://images.unsplash.com/photo-1604654894610-df63bc536371?auto=format&fit=crop&q=80&w=1920";
---

<section class="hero">
  <div class="hero-background">
    <img src={heroImg} alt="Savec Nails salon" class="hero-bg-img" />
    <div class="hero-overlay"></div>
  </div>

  <div class="container hero-content">
    <div class="content-wrapper">
      <span class="subtitle">Nuevo local en Villa El Salvador</span>
      <h1 class="title">Arte y cuidado<br /><span>en tus manos</span></h1>
      <p class="description">
        Donde la técnica, la delicadeza y el confort se encuentran para resaltar
        tu belleza natural.
      </p>
      <div class="button-group">
        <a
          href={contactInfo.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          Reservar Cita
        </a>
        <a href="/savec-nails" class="btn btn-outline"> Ver Servicios </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    overflow: hidden;
    background-color: var(
      --text-main
    ); /* Color base por si la imagen tarda en cargar */
  }

  /* Fondo e Imagen */
  .hero-background {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    /* Gradiente oscuro para legibilidad del texto */
    background: linear-gradient(
      to right,
      rgba(53, 39, 41, 0.85) 0%,
      rgba(53, 39, 41, 0.4) 50%,
      transparent 100%
    );
  }

  /* Contenedor y Contenido */
  .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    position: relative;
    z-index: 10;
  }

  .content-wrapper {
    max-width: 600px;
    animation: var(--anim-fade-up); /* Tu animación de los :root */
  }

  .subtitle {
    display: inline-block;
    font-size: 0.875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--primary); /* El rosa glow */
    margin-bottom: 1rem;
    font-family: var(--font-body);
  }

  .title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 8vw, 4rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--primary-text);
    margin-bottom: 1.5rem;
  }

  .title span {
    color: var(--primary); /* Opcional: resaltar la segunda línea */
  }

  .description {
    font-family: var(--font-body);
    font-size: 1.125rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 2.5rem;
  }

  /* Botones */
  .button-group {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn {
    padding: 0.9rem 2.2rem;
    border-radius: 9999px;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    transition: all 0.3s ease;
    font-family: var(--font-body);
  }

  .btn-primary {
    background: var(--gradient-rose);
    color: white;
    box-shadow: var(--shadow-rose-lg);
  }

  .btn-primary:hover {
    transform: translateY(-3px) scale(1.05);
    filter: brightness(1.1);
  }

  .btn-outline {
    border: 1px solid rgba(255, 255, 255, 0.3);
    color: white;
    backdrop-filter: blur(4px);
  }

  .btn-outline:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: white;
  }

  /* Responsive Mobile */
  @media (max-width: 768px) {
    .hero {
      text-align: center;
      justify-content: center;
    }

    .hero-overlay {
      background: rgba(53, 39, 41, 0.6);
    }

    .content-wrapper {
      margin: 0 auto;
    }

    .button-group {
      justify-content: center;
    }
  }
</style>
