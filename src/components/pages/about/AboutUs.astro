---
const aboutImg =
  "https://images.unsplash.com/photo-1632345031435-8727f6897d53?auto=format&fit=crop&q=80&w=1000";

const features = [
  {
    icon: "gem",
    text: "Productos profesionales premium.",
    svg: `<path d="M6 3h12l4 6-10 12L2 9z"></path><path d="M11 3v18"></path><path d="M5 13l4-4 4 4 4-4"></path>`,
  },
  {
    icon: "shield",
    text: "Protocolos estrictos de higiene y esterilización.",
    svg: `<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="m9 12 2 2 4-4"></path>`,
  },
  {
    icon: "coffee",
    text: "Coffee Bar incluido como parte de tu experiencia.",
    svg: `<path d="M17 8h1a4 4 0 1 1 0 8h-1"></path><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"></path><path d="M6 2v2"></path><path d="M10 2v2"></path><path d="M14 2v2"></path>`,
  },
];
---

<section class="experience-section">
  <div class="container">
    <div class="experience-grid">
      <div class="image-wrapper">
        <img src={aboutImg} alt="Experiencia Savec" class="experience-img" />
      </div>

      <div class="content">
        <header class="header">
          <span class="subtitle">Experiencia Savec</span>
          <h2 class="title">Tu bienestar es nuestra prioridad</h2>
        </header>

        <div class="features-list">
          {
            features.map((item) => (
              <div class="feature-item">
                <div class="icon-box">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon-svg"
                    set:html={item.svg}
                  />
                </div>
                <p class="feature-text">{item.text}</p>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .experience-section {
    padding: 5rem 1.5rem;
    background-color: var(--background);
  }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .experience-grid {
    display: grid;
    gap: 3rem;
    align-items: center;
  }

  /* IMAGEN */
  .experience-img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 1.5rem;
    box-shadow: var(--shadow-rose-lg);
  }

  /* HEADER */
  .header {
    margin-bottom: 1.5rem;
  }

  .subtitle {
    display: inline-block;
    font-size: var(--text-sm);
    font-weight: var(--font-semibold);
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 0.5rem;
    font-family: var(--font-body);
  }

  .title {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: var(--font-bold);
    color: var(--text-main);
    line-height: 1.2;
  }

  .features-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .feature-item {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .icon-box {
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 50%;
    background: var(--gradient-rose);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    margin-top: 0.2rem;
  }

  .icon-svg {
    width: 1.1rem;
    height: 1.1rem;
    color: white;
  }

  .feature-text {
    font-family: var(--font-body);
    color: var(--muted-text);
    line-height: 1.6;
    font-size: var(--text-base);
  }

  @media (min-width: 768px) {
    .experience-grid {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
  }
</style>
