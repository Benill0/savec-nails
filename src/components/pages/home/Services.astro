---
import { contactInfo } from "../../../data/contact";
import ServiceCard from "../../common/ServiceCard.astro";
import SectionHeading from "../../SectionHeading.astro";

const featuredServices = [
  "Manicura Rusa",
  "Pedicura Spa",
  "Soft Gel",
  "Uñas Acrílicas",
  "Polygel",
  "Diseño High-End",
  "Baño de Gel",
  "Retirado Seguro",
];
---

<section class="featured-services">
  <div class="container">
    <SectionHeading
      subtitle="Servicios Destacados"
      title="Experiencia Completa de Belleza"
      description="Especialistas en el cuidado profesional de manos y pies con las últimas técnicas del mercado."
    />

    <div class="services-grid">
      {
        featuredServices.map((service, index) => (
          <ServiceCard title={service} index={index} icon="lucide:sparkles" />
        ))
      }
    </div>

    <div class="cta-wrapper">
      <a
        href={contactInfo.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-cta"
      >
        Reservar Cita
      </a>
    </div>
  </div>
</section>

<style>
  /* BASE: MOBILE FIRST */
  .featured-services {
    padding: 5rem 1.5rem;
    background-color: var(--background);
  }

  .container {
    width: min(100%, var(--max-width));
    display: grid;
    gap: 3rem;
    margin: 0 auto;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
  }

  .cta-wrapper {
    margin-top: 3rem;
    text-align: center;
    animation: var(--anim-fade-up);
    animation-delay: 0.5s;
  }

  .btn-cta {
    display: inline-block;
    padding: 0.9rem 2.5rem;
    background: var(--gradient-rose);
    color: white;
    text-decoration: none;
    border-radius: 9999px;
    font-weight: 600;
    font-family: var(--font-body);
    box-shadow: var(--shadow-rose);
    transition: all 0.3s ease;
  }

  .btn-cta:hover {
    transform: scale(1.05);
    box-shadow: var(--shadow-rose-lg);
  }

  /* MEDIA QUERIES PARA VISTAS MÁS GRANDES */

  /* Tablets (md) */
  @media (min-width: 48rem) {
    .services-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  /* Desktop (lg) */
  @media (min-width: 64rem) {
    .services-grid {
      grid-template-columns: repeat(4, 1fr);
    }

    .featured-services {
      padding: 7rem 2rem;
    }
  }
</style>
