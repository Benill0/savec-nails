---
const WHATSAPP_LINK = "https://wa.me/tu-numero";
const bgImage =
  "https://images.unsplash.com/photo-1632345031435-8727f6897d53?q=80&w=1470&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D";
---

<section class="booking-cta">
  <div class="overlay-image">
    <img src={bgImage} alt="" />
  </div>

  <div class="container relative-z">
    <h2 class="title">Reserva tu Cita</h2>
    <p class="description">
      Agenda tu próxima visita y vive la experiencia Savec Nails.
    </p>

    <a
      href={WHATSAPP_LINK}
      target="_blank"
      rel="noopener noreferrer"
      class="btn-booking"
    >
      💅 Reserva tu cita aquí
    </a>
  </div>
</section>

<style>
  .booking-cta {
    position: relative;
    padding: 5rem 1.5rem;
    background: var(--gradient-rose);
    overflow: hidden;
    text-align: center;
  }

  .overlay-image {
    position: absolute;
    inset: 0;
    opacity: 0.1;
    z-index: 1;
  }

  .overlay-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .relative-z {
    position: relative;
    z-index: 10;
  }

  .title {
    font-size: var(--text-3xl);
    font-weight: var(--font-bold);
    color: var(--primary-text);
    margin-bottom: 1rem;
  }

  .description {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    color: rgba(255, 255, 255, 0.8);
    max-width: 32rem;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .btn-booking {
    display: inline-block;
    padding: 1rem 2.5rem;
    background-color: var(--card);
    color: var(--primary);
    font-weight: var(--font-bold);
    font-size: var(--text-lg);
    text-decoration: none;
    border-radius: 9999px;
    font-family: var(--font-body);
    box-shadow: var(--shadow-rose-lg);
    transition: transform 0.3s ease;
  }

  .btn-booking:hover {
    transform: scale(1.05);
  }

  @media (min-width: 768px) {
    .booking-cta {
      padding: 5rem 1.5rem;
    }

    .title {
      font-size: var(--text-5xl);
    }
  }
</style>
